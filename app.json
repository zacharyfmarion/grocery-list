{
  "expo": {
    "name": "Cartful",
    "slug": "cartful",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cartful",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cartful.app",
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#329f3d"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cartful.app",
      "adaptiveIcon": {
        "backgroundColor": "#329f3d",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0f6cff1d-4f5d-4d15-ac77-3415978fb101"
      }
    },
    "owner": "zacharyfmarion"
  }
}
