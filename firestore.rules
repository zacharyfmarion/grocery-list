rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: only the owner can read/write their own profile.
    // Anyone authenticated can read profiles (needed for share-by-email lookup).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth.uid == userId;
    }

    // Grocery lists: only members (owner + sharedWith) can access.
    match /lists/{listId} {
      function isMember() {
        return request.auth != null &&
               request.auth.uid in resource.data.members;
      }

      function willBeMember() {
        return request.auth != null &&
               request.auth.uid in request.resource.data.members;
      }

      // Read: must be a current member
      allow read: if isMember();

      // Create: authenticated user, must include themselves as owner and member
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.auth.uid in request.resource.data.members;

      // Update: must be a current member and remain a member after update
      allow update: if isMember() && willBeMember();

      // Delete: only the owner can delete
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;

      // Items subcollection: accessible to list members
      match /items/{itemId} {
        function isListMember() {
          return request.auth != null &&
                 request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.members;
        }

        allow read, write: if isListMember();
      }
    }

    // User preferences: only the owner can read/write
    match /userPreferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User item history: only the owner can read/write
    match /userHistory/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Templates: only the owner can read/write their own templates
    match /templates/{templateId} {
      allow read: if request.auth != null
                  && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null
                   && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.ownerUid == request.auth.uid;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
